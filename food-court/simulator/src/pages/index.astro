---
import '../styles/global.css';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Digital playtest simulator for the Food Court board game rules."
    />
    <title>Food Court Simulator</title>
  </head>
  <body>
    <div id="app"></div>
    <script>
      import { mountFoodCourtApp } from '../game/app';

      const root = document.getElementById('app');
      if (root) mountFoodCourtApp(root);
    </script>
  </body>
</html>
